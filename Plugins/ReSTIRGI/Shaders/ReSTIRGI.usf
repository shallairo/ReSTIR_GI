StructuredBuffer<FReSTIRGIPackedReservoir> HistoryReservoir;
StructuredBuffer<FReSTIRGIPackedReservoir> SourceReservoir;
StructuredBuffer<FReSTIRGIPackedReservoir> FinalReservoir;
RWStructuredBuffer<FReSTIRGIPackedReservoir> TemporalReservoir;
RWStructuredBuffer<FReSTIRGIPackedReservoir> SpatialReservoir;
RWStructuredBuffer<FReSTIRGIPackedReservoir> HistoryReservoirOutput;
StructuredBuffer<uint> NeighborOffsetBuffer;
RWTexture2D<float4> OutputTexture;
