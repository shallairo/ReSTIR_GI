// --- Radiance mode constants ---
#define RADIANCE_SCREEN_PROJECTED 0
#define RADIANCE_SYNTHETIC_CONST  1
#define RADIANCE_NORMAL_COLOR     2
#define RADIANCE_ALBEDO_COLOR     3

struct FReSTIRGISurface
{
	float4 WorldPositionAndDepth;
	float4 NormalAndRoughness;
	float4 BaseColorAndSpecular;
	float4 Misc;
};

struct FReSTIRGIPackedReservoir
{
	float4 SamplePositionAndWeight; // xyz = position, w = weightSum
	float4 SampleNormalAndPdf;      // xyz = normal,   w = samplePdf
	float4 RadianceAndM;            // xyz = radiance, w = M (candidate count)
	uint4  Misc;                    // x = age, y = valid, z = miss, w = pad
};

struct FReSTIRGIStats
{
	uint4 PrimaryValidAndHitAndInitValid; // x=primaryValid, y=secondaryHit, z=initValid, w=count
	uint4 TemporalSpatialValidAndCount;   // x=temporalValid, y=spatialValid, z=finalValid, w=count
	uint4 Pad1;
	uint4 Pad2;
};

Texture2D<float4> SceneColorTexture;
SamplerState SceneColorSampler;
RaytracingAccelerationStructure TLAS;

RWStructuredBuffer<FReSTIRGISurface> PrimarySurfaceBuffer;
RWStructuredBuffer<FReSTIRGISurface> SecondarySurfaceBuffer;
StructuredBuffer<FReSTIRGISurface> HistoryPrimarySurfaceBuffer;
StructuredBuffer<FReSTIRGISurface> PrimarySurfaceBufferSRV;
StructuredBuffer<FReSTIRGISurface> SecondarySurfaceBufferSRV;
RWStructuredBuffer<FReSTIRGISurface> HistoryPrimarySurfaceOutput;

